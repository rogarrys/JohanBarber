# Copie ce fichier en ".env" puis remplis les valeurs.
# (Le fichier .env ne doit jamais être partagé ni mis en ligne publiquement.)

# Jeton du bot Telegram, donné par @BotFather
TELEGRAM_BOT_TOKEN=

# Ton identifiant de conversation Telegram (obtenu via: npm run chat-id)
TELEGRAM_CHAT_ID=

# Port du serveur (optionnel, 3000 par défaut)
PORT=3000
