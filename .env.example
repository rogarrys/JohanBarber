# Copie ce fichier en ".env" puis remplis les valeurs.
# (Le fichier .env ne doit jamais être partagé ni mis en ligne publiquement.)

# --- Telegram (notifications instantanées) ---
# Jeton du bot, donné par @BotFather
TELEGRAM_BOT_TOKEN=
# Ton identifiant de conversation (obtenu via: npm run chat-id)
TELEGRAM_CHAT_ID=

# --- Panel admin (/admin) ---
# Mot de passe pour te connecter à ton espace barbier
ADMIN_PASSWORD=change-moi

# --- E-mail (optionnel) ---
# Clé API Resend (https://resend.com) + ton adresse de réception
EMAIL_API_KEY=
EMAIL_TO=
EMAIL_FROM=JOHAN Barbier <onboarding@resend.dev>

# --- Base de données Supabase (stockage persistant des réservations/réglages) ---
# URL du projet (https://<ref>.supabase.co) + clé SECRÈTE (service_role / sb_secret_...)
SUPABASE_URL=
SUPABASE_KEY=

# --- Divers ---
PORT=3000
